<div class="container mt-5">
  <h1>New Game</h1>
  <div class="d-flex mb-3">
    <% @letters.each do |letter| %>
      <div class="p-3 m-1 bg-primary text-white font-weight-bold shadow-sm"><%= letter %></div>
    <% end %>
  </div>

  <p>What is the longest word you can find?</p>
  <form action="/score" method="POST" data-turbo="false" class="form-inline">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <%= hidden_field_tag :letters, @letters %>
    <div class="input-group mb-3">
      <input type="text" name="word" class="form-control">
      <button type="submit" class="btn btn-primary">Play</button>
    </div>
  </form>
</div>
